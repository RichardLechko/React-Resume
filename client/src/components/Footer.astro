---
import { useTranslations, type Lang } from '../i18n';
import styles from '../styles/Footer.module.css';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Update this when the site's CONTENT meaningfully changes (new role, new
// project, redesign). Build date stays out of it — that would lie every
// time we redeploy a CSS tweak.
const LAST_UPDATED_ISO = '2026-06-28';

const lastUpdated = new Date(LAST_UPDATED_ISO).toLocaleDateString(
  lang === 'ru' ? 'ru-RU' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' },
);
const fallbackYear = new Date().getFullYear();
---
<footer class={styles.footer}>
  <div class={styles.footerContainer}>
    <small>
      &copy; <span data-current-year>{fallbackYear}</span> {t('footer.name')} | {t('footer.copyrightSuffix')}
    </small>
    <time datetime={LAST_UPDATED_ISO}>
      {t('footer.lastUpdated')} {lastUpdated}
    </time>
  </div>
</footer>

<script>
  const el = document.querySelector<HTMLElement>('[data-current-year]');
  if (el) el.textContent = String(new Date().getFullYear());
</script>

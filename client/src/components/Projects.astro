---
import { Icon } from 'astro-icon/components';
import { useTranslations, type Lang } from '../i18n';
import projects from '../data/projects';
import Highlight from './Highlight.astro';
import styles from '../styles/Projects.module.css';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const projectItems = projects.map((p) => {
  const base = `projects.items.${p.id}`;
  return {
    ...p,
    name: t(`${base}.name`) as string,
    description: t(`${base}.description`) as string,
  };
});
---
<main id="projects" lang={lang}>
  <header>
    <h2 class="section-title">{t('projects.title')}</h2>
  </header>

  <div class={styles.projectsGridInner}>
    {projectItems.map((p) => (
      <article class={`${styles.projectCard} fade-on-scroll`} lang={lang}>
        <header class={styles.projectHeader}>
          <nav class={styles.projectTechStack} aria-label="Technologies used">
            {p.techStack.map((tech) => <small class={styles.techTag}>{tech}</small>)}
          </nav>
          {!p.isPrivate && !p.inDevelopment && (
            <nav class={styles.projectLinks} aria-label="Project links">
              {p.sourceLink && (
                <a href={p.sourceLink} target="_blank" rel="noopener noreferrer" class={styles.projectLinkButton} aria-label={t('common.viewSource') as string}>
                  <Icon name="lucide:chevrons-left-right" />
                </a>
              )}
              {p.liveLink && (
                <a href={p.liveLink} target="_blank" rel="noopener noreferrer" class={styles.projectLinkButton} aria-label={t('common.viewLive') as string}>
                  <Icon name="lucide:mouse-pointer-click" />
                </a>
              )}
            </nav>
          )}
          {p.inDevelopment && <small class={styles.developmentBadge}>{t('projects.inDevelopment') as string}</small>}
        </header>
        <h3 class={styles.projectTitle}>{p.name}</h3>
        <div class={styles.projectDescription}>
          <p><Highlight text={p.description} /></p>
        </div>
      </article>
    ))}
  </div>
</main>

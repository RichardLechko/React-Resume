---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  lang="en"
  title="404 — Not Found · Richard Lechko"
  description="The page you were looking for doesn't exist."
>
  <main class="notfound">
    <p class="eyebrow">404 — Not Found</p>
    <h1 class="headline">
      <span>This page</span><br />
      <em>doesn't exist.</em>
    </h1>
    <p class="copy">
      You may have followed an old link, or made a typo somewhere along the way.
      Either way, the rest of the site is intact.
    </p>
    <nav class="links" aria-label="Recovery navigation">
      <a href="/">← Home</a>
      <span aria-hidden="true">·</span>
      <a href="/ru/">Русская версия</a>
    </nav>
  </main>
</BaseLayout>

<style>
  .notfound {
    min-height: 100vh;
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
  }

  .eyebrow {
    font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-color);
    margin: 0;
  }

  .headline {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0;
    color: var(--text-color);
    text-align: left;
  }

  .headline em {
    font-style: italic;
    font-weight: 500;
    color: var(--secondary);
  }

  .copy {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--secondary);
    max-width: 50ch;
    margin: 0;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.9rem;
  }

  .links a {
    color: var(--accent-color);
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 1px solid var(--accent-bg);
    transition: border-color 0.15s ease;
  }

  .links a:hover {
    border-bottom-color: var(--accent-color);
  }

  .links span {
    color: var(--secondary);
    opacity: 0.5;
  }
</style>
